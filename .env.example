# SQL Server（azure-sql-edge / Apple Silicon ARM64）
# 為什麼留這兩個變數：docker-compose mssql service 會讀；密碼必須符合 SQL Server 複雜度
# （≥8 chars、含大小寫/數字/符號），改密碼時兩個值要一起更新 client 端連線字串。
MSSQL_SA_PASSWORD=Your_password123!
# 預設由 mssql-init sidecar 建立的空資料庫名稱（與 postgres 上的 AOIOpsPlatform 區分）
MSSQL_DB=AOIOpsPlatform_MSSQL

# OpenAI（Knowledge Copilot）
OPENAI_API_KEY=

